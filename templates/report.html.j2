<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>mRNA Design Pipeline - {{ title }}</title>
    <script src="https://cdn.plot.ly/plotly-latest.min.js"></script>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        .header { background: #1a1a2e; color: white; padding: 20px; border-radius: 10px; }
        .stats { display: flex; gap: 20px; margin: 20px 0; }
        .stat-box { background: #f0f0f0; padding: 15px; border-radius: 8px; flex: 1; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { padding: 10px; text-align: left; border-bottom: 1px solid #ddd; }
        th { background: #667eea; color: white; }
    </style>
</head>
<body>
    <div class="header">
        <h1>🧬 mRNA Design Pipeline Results</h1>
        <p>Generated: {{ timestamp }}</p>
    </div>
    
    <div class="stats">
        <div class="stat-box">
            <h3>Total Candidates</h3>
            <p>{{ total_candidates }}</p>
        </div>
        <div class="stat-box">
            <h3>Top Score</h3>
            <p>{{ top_score }}</p>
        </div>
        <div class="stat-box">
            <h3>Average Score</h3>
            <p>{{ avg_score }}</p>
        </div>
    </div>
    
    <h2>Top Candidates</h2>
    <table>
        <thead>
            <tr>
                <th>Rank</th>
                <th>ID</th>
                <th>Score</th>
                <th>CAI</th>
                <th>tAI</th>
                <th>GC%</th>
                <th>MFE</th>
            </tr>
        </thead>
        <tbody>
            {% for candidate in candidates %}
            <tr>
                <td>#{{ candidate.rank }}</td>
                <td>{{ candidate.id }}</td>
                <td><strong>{{ candidate.composite_score }}</strong></td>
                <td>{{ candidate.CAI }}</td>
                <td>{{ candidate.tAI }}</td>
                <td>{{ candidate.GC_content }}</td>
                <td>{{ candidate.MFE }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</body>
</html>
