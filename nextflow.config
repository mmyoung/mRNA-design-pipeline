// Nextflow config for mRNA Design Pipeline
process {
    executor = 'local'
    conda = 'biopython,bioconda::viennarna,plotly,pandas,numpy,jinja2'
}

// Parameters
params {
    input = null                  // Input amino acid sequence (file or string)
    output_dir = 'results'        // Output directory
    sample_seqs = 100             // Number of candidate sequences to sample
    weights = 'default'           // Weight configuration file
    
    // Default weights for scoring (can be customized)
    weight_cai = 0.20
    weight_tai = 0.15
    weight_gc = 0.15
    weight_mfe = 0.15
    weight_cpg = 0.15
    weight_kozak = 0.10
    weight_polyA = 0.10
}

